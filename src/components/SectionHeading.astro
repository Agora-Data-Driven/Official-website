---
interface Props {
  eyebrow?: string;
  title: string;
  align?: 'left' | 'center';
  class?: string;
}
const { eyebrow, title, align = 'left', class: className = '' } = Astro.props;
const wrap = align === 'center' ? 'mx-auto text-center' : '';
const eyebrowJustify = align === 'center' ? 'justify-center' : '';
---

<div class={`max-w-2xl ${wrap} ${className}`}>
  {
    eyebrow && (
      <p class={`eyebrow flex items-center gap-2.5 ${eyebrowJustify}`}>
        <span class="h-px w-6 bg-brand-500" aria-hidden="true" />
        {eyebrow}
      </p>
    )
  }
  <h2 class="mt-4 text-3xl font-bold text-ink sm:text-[2.6rem] sm:leading-[1.05]">{title}</h2>
  <slot />
</div>
