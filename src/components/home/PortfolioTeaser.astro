---
import Container from '@components/Container.astro';
import SectionHeading from '@components/SectionHeading.astro';
import Button from '@components/Button.astro';
import { caseStudies, competitions } from '@data/portfolio';

const medals = ['🥈', '🥇'];
---

<section class="border-line border-b py-16 lg:py-24">
  <Container>
    <div class="reveal flex flex-col justify-between gap-6 sm:flex-row sm:items-end">
      <SectionHeading eyebrow="Portfolio" title="Real-life results, not just a list of projects">
        <p class="text-muted mt-3">
          Every campaign reflects a challenge we tackled, a strategy we shaped, and the results we
          delivered.
        </p>
      </SectionHeading>
      <Button href="/agora-portfolio/" variant="secondary">Explore the portfolio</Button>
    </div>

    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {
        caseStudies.map((c, i) => (
          <article
            class="card-hover reveal group border-line bg-surface flex flex-col rounded-2xl border p-6"
            style={`--reveal-delay: ${i * 90}ms`}
          >
            <span class="bg-tint text-brand-700 w-fit rounded-full px-3 py-1 text-xs font-semibold">
              {c.tag}
            </span>
            <h3 class="text-ink mt-4 text-xl font-semibold">{c.cardTitle}</h3>
            <p class="text-muted mt-2 flex-1 text-sm">{c.summary}</p>
            {c.metrics && (
              <div class="border-line mt-5 flex flex-wrap gap-x-5 gap-y-2 border-t pt-4">
                {c.metrics.slice(0, 2).map((m) => (
                  <div>
                    <div class="font-display text-brand-600 text-lg font-bold tabular-nums">
                      {m.value}
                    </div>
                    <div class="text-muted text-[0.7rem] leading-tight">{m.label}</div>
                  </div>
                ))}
              </div>
            )}
            <a
              href={`/${c.slug}/`}
              class="text-brand-600 hover:text-brand-700 mt-5 inline-flex items-center gap-1 text-sm font-semibold transition-colors"
            >
              Learn more
              <span
                class="transition-transform duration-200 group-hover:translate-x-1"
                aria-hidden="true"
              >
                &rarr;
              </span>
            </a>
          </article>
        ))
      }
    </div>

    <div class="mt-6 grid gap-6 sm:grid-cols-2">
      {
        competitions.map((c, i) => (
          <a
            href={`/${c.slug}/`}
            class="card-hover reveal group border-line bg-surface flex items-center gap-4 rounded-2xl border p-6"
            style={`--reveal-delay: ${i * 90}ms`}
          >
            <span
              class="bg-tint grid h-12 w-12 shrink-0 place-items-center rounded-xl text-2xl"
              aria-hidden="true"
            >
              {medals[i] ?? '🏅'}
            </span>
            <div class="min-w-0">
              <div class="font-display text-ink text-base font-bold">{c.placement}</div>
              <div class="text-muted truncate text-sm">{c.event}</div>
            </div>
            <span
              class="text-brand-600 ml-auto hidden shrink-0 transition-transform duration-200 group-hover:translate-x-1 sm:inline"
              aria-hidden="true"
            >
              &rarr;
            </span>
          </a>
        ))
      }
    </div>
  </Container>
</section>
