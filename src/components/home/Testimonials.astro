---
import Container from '@components/Container.astro';
import SectionHeading from '@components/SectionHeading.astro';
import { testimonials } from '@data/testimonials';
---

<section class="border-line bg-surface border-b py-16 lg:py-24">
  <Container>
    <SectionHeading eyebrow="Client results" title="Trusted by clients on Upwork" class="reveal">
      <p class="text-muted mt-3">Feedback from real engagements on our Upwork agency profile.</p>
    </SectionHeading>

    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        testimonials.map((t, i) => (
          <figure
            class="card-hover reveal border-line bg-canvas relative flex flex-col overflow-hidden rounded-2xl border p-6"
            style={`--reveal-delay: ${(i % 3) * 90}ms`}
          >
            <span
              class="font-display text-brand-200 pointer-events-none absolute -top-4 right-5 text-8xl leading-none select-none"
              aria-hidden="true"
            >
              &rdquo;
            </span>
            <div
              class="from-brand-500 to-emerald absolute inset-x-0 top-0 h-1 bg-linear-to-r"
              aria-hidden="true"
            />
            <div class="text-brand-500 relative flex gap-0.5 text-base" aria-hidden="true">
              ★★★★★
            </div>
            <blockquote class="text-body relative mt-4 flex-1">"{t.quote}"</blockquote>
            <figcaption class="border-line font-display text-muted mt-6 flex items-center gap-2 border-t pt-4 text-xs tracking-wider uppercase">
              <svg
                class="text-brand-500 h-4 w-4"
                viewBox="0 0 20 20"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  fill-rule="evenodd"
                  d="M16.7 5.3a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0l-3.5-3.5a1 1 0 1 1 1.4-1.4l2.8 2.79 6.8-6.79a1 1 0 0 1 1.4 0Z"
                  clip-rule="evenodd"
                />
              </svg>
              Verified · {t.source}
            </figcaption>
          </figure>
        ))
      }
    </div>
  </Container>
</section>
