---
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '@components/Container.astro';

interface Props {
  eyebrow?: string;
  title: string;
  summary: string;
  heroImage?: string;
  heroAlt?: string;
  metrics?: { value: string; label: string }[];
}
const { eyebrow, title, summary, heroImage, heroAlt, metrics } = Astro.props;
---

<BaseLayout title={title} description={summary} ogImage={heroImage}>
  <section class="border-line from-tint/40 to-canvas border-b bg-linear-to-b">
    <Container size="narrow" class="pt-10 pb-8 lg:pt-12 lg:pb-10">
      <a href="/agora-portfolio/" class="text-brand-600 hover:text-brand-700 text-sm font-medium"
        >&larr; Back to portfolio</a
      >
      {
        eyebrow && (
          <p class="text-brand-600 mt-6 text-sm font-semibold tracking-wide uppercase">{eyebrow}</p>
        )
      }
      <h1 class="text-ink mt-2 text-4xl font-bold sm:text-5xl">{title}</h1>
      <p class="text-muted mt-4 max-w-2xl text-lg">{summary}</p>
    </Container>
  </section>

  {
    heroImage && (
      <Container size="narrow" class="pt-6 lg:pt-8">
        <img
          src={heroImage}
          alt={heroAlt ?? ''}
          class="border-line bg-canvas aspect-[16/9] w-full rounded-2xl border object-cover"
          loading="eager"
        />
      </Container>
    )
  }

  {
    metrics && metrics.length > 0 && (
      <Container size="narrow" class="pt-10">
        <div class="grid gap-4 sm:grid-cols-3">
          {metrics.map((m) => (
            <div class="border-line bg-surface rounded-2xl border p-6 text-center">
              <div class="font-display text-brand-600 text-3xl font-bold tracking-tight tabular-nums">
                {m.value}
              </div>
              <div class="text-muted mt-1 text-sm">{m.label}</div>
            </div>
          ))}
        </div>
      </Container>
    )
  }

  <Container size="narrow" class="py-10 lg:py-14">
    <div class="prose">
      <slot />
    </div>
  </Container>

  <section class="border-line bg-surface border-t">
    <Container class="py-12 text-center">
      <h2 class="text-ink text-2xl font-bold">Want results like these?</h2>
      <p class="text-muted mx-auto mt-2 max-w-lg">
        Let's turn your data into sales. Hire us on Upwork.
      </p>
    </Container>
  </section>
</BaseLayout>
