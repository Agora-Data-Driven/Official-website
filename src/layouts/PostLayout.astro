---
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '@components/Container.astro';
import { site } from '@data/site';

interface Props {
  title: string;
  publishDate: Date;
  updatedDate?: Date;
  excerpt: string;
  heroImage?: string;
  heroAlt?: string;
  category?: string;
}
const { title, publishDate, updatedDate, excerpt, heroImage, heroAlt, category } = Astro.props;

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const canonical = new URL(Astro.url.pathname, site.url).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: excerpt,
  datePublished: publishDate.toISOString(),
  ...(updatedDate ? { dateModified: updatedDate.toISOString() } : {}),
  ...(heroImage ? { image: heroImage } : {}),
  author: { '@type': 'Organization', name: site.name, url: site.url },
  publisher: { '@type': 'Organization', name: site.name, url: site.url },
  mainEntityOfPage: canonical,
};
---

<BaseLayout title={title} description={excerpt} ogImage={heroImage} type="article">
  <article>
    <Container size="narrow" class="pt-12 pb-8 lg:pt-16">
      <a href="/blog/" class="text-sm font-medium text-brand-600 hover:text-brand-700"
        >&larr; All articles</a
      >
      {
        category && (
          <p class="mt-6 text-sm font-semibold tracking-wide text-brand-600 uppercase">{category}</p>
        )
      }
      <h1 class="mt-2 text-4xl font-bold text-ink sm:text-5xl">{title}</h1>
      <p class="mt-4 text-sm text-muted">
        <time datetime={publishDate.toISOString()}>{fmt(publishDate)}</time>{
          updatedDate ? ` · Updated ${fmt(updatedDate)}` : ''
        }
      </p>
    </Container>

    {
      heroImage && (
        <Container size="narrow">
          <img
            src={heroImage}
            alt={heroAlt ?? ''}
            class="aspect-[16/9] w-full rounded-2xl border border-line bg-canvas object-cover"
            loading="eager"
          />
        </Container>
      )
    }

    <Container size="narrow" class="py-10">
      <div class="prose">
        <slot />
      </div>
    </Container>
  </article>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
</BaseLayout>
