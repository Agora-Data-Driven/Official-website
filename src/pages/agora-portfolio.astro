---
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '@components/Container.astro';
import SectionHeading from '@components/SectionHeading.astro';
import Button from '@components/Button.astro';
import { caseStudies, competitions } from '@data/portfolio';

export const prerender = true;
---

<BaseLayout
  title="Portfolio"
  description="Real-life results from Agora Data Driven: client case studies and award-winning analytics competition placements."
>
  <section class="border-b border-line bg-gradient-to-b from-tint/50 to-canvas">
    <Container class="py-16 lg:py-24">
      <p class="text-sm font-semibold tracking-wide text-brand-600 uppercase">Portfolio</p>
      <h1 class="mt-2 max-w-3xl text-4xl font-bold text-ink sm:text-5xl">Explore our portfolio</h1>
      <p class="mt-4 max-w-2xl text-lg text-muted">
        Our portfolio isn't just a list of projects — it's proof of how we solve problems, drive
        growth, and adapt fast. Every campaign reflects a challenge we've tackled, a strategy we've
        shaped, and the results we've delivered.
      </p>
    </Container>
  </section>

  <!-- Case studies -->
  <section id="case-studies" class="border-b border-line py-16 lg:py-24">
    <Container>
      <SectionHeading eyebrow="Case studies" title="Real-life results">
        <p class="mt-3 text-muted">
          From concept to execution, each case shows our problem-solving approach and results-driven
          mindset.
        </p>
      </SectionHeading>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {
          caseStudies.map((c) => (
            <article class="flex flex-col overflow-hidden rounded-2xl border border-line bg-surface shadow-card transition-shadow hover:shadow-pop">
              <a href={`/${c.slug}/`} class="block">
                <img
                  src={c.heroImage}
                  alt=""
                  class="aspect-[16/10] w-full bg-canvas object-cover"
                  loading="lazy"
                />
              </a>
              <div class="flex flex-1 flex-col p-6">
                <span class="w-fit rounded-full bg-tint px-3 py-1 text-xs font-semibold text-brand-700">
                  {c.tag}
                </span>
                <h3 class="mt-3 text-xl font-semibold text-ink">{c.cardTitle}</h3>
                <p class="mt-2 flex-1 text-sm text-muted">{c.summary}</p>
                <a
                  href={`/${c.slug}/`}
                  class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-brand-600 hover:text-brand-700"
                >
                  Learn more <span aria-hidden="true">&rarr;</span>
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </Container>
  </section>

  <!-- Competitions -->
  <section id="competitions" class="border-b border-line bg-surface py-16 lg:py-24">
    <Container>
      <SectionHeading eyebrow="Competitions" title="Skill meets growth">
        <p class="mt-3 text-muted">
          We regularly enter industry analytics challenges to stay sharp — and we win.
        </p>
      </SectionHeading>
      <div class="mt-10 grid gap-6 md:grid-cols-2">
        {
          competitions.map((c) => (
            <a
              href={`/${c.slug}/`}
              class="flex flex-col rounded-2xl border border-line bg-canvas p-7 transition-shadow hover:shadow-pop"
            >
              <span class="text-3xl font-bold text-brand-600">{c.placement}</span>
              <h3 class="mt-3 text-xl font-semibold text-ink">{c.cardTitle}</h3>
              <p class="mt-2 text-sm text-muted">{c.event}</p>
              <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-brand-600">
                See the project <span aria-hidden="true">&rarr;</span>
              </span>
            </a>
          ))
        }
      </div>
    </Container>
  </section>

  <!-- Web development -->
  <section class="py-16 lg:py-24">
    <Container>
      <div
        class="flex flex-col items-start justify-between gap-6 rounded-2xl border border-line bg-surface p-8 lg:flex-row lg:items-center"
      >
        <div>
          <h2 class="text-2xl font-bold text-ink">Looking for high-performance web development?</h2>
          <p class="mt-2 max-w-2xl text-muted">
            We build fast, responsive, conversion-focused business websites using modern stacks like
            React, Vite, and WordPress.
          </p>
        </div>
        <Button href="https://webdev.agoradatadriven.com/" external variant="secondary" size="lg">
          View web development
        </Button>
      </div>
    </Container>
  </section>
</BaseLayout>
