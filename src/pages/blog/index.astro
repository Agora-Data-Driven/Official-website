---
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '@components/Container.astro';
import { getCollection } from 'astro:content';

export const prerender = true;

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime(),
);
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout
  title="Blog"
  description="Insights on data-driven marketing, analytics, and growth from Agora Data Driven."
>
  <section class="border-line from-tint/40 to-canvas border-b bg-linear-to-b">
    <Container class="py-16 lg:py-20">
      <p class="eyebrow">Blog</p>
      <h1 class="text-ink mt-2 text-4xl font-bold sm:text-5xl">Latest from the blog</h1>
      <p class="text-muted mt-3 max-w-2xl">
        Practical insights on analytics-powered marketing, full-funnel growth, and what actually
        moves the needle.
      </p>
    </Container>
  </section>

  <Container class="py-12 lg:py-16">
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        posts.map((post) => (
          <article class="border-line bg-surface shadow-card card-hover flex flex-col rounded-2xl border p-6">
            <p class="text-brand-600 text-xs font-semibold tracking-wide uppercase">
              {post.data.category}
            </p>
            <h2 class="text-ink mt-2 text-lg font-semibold">
              <a href={`/${post.id}/`} class="hover:text-brand-700">
                {post.data.title}
              </a>
            </h2>
            <p class="text-muted mt-2 flex-1 text-sm">{post.data.excerpt}</p>
            <p class="text-muted mt-4 text-xs">{fmt(post.data.publishDate)}</p>
          </article>
        ))
      }
    </div>
  </Container>
</BaseLayout>
