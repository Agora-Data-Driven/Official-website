---
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '@components/Container.astro';

export const prerender = true;
const updated = 'June 2026';
---

<BaseLayout title="Privacy Policy" description="Privacy policy for Agora Data Driven." noindex>
  <Container size="narrow" class="py-16 lg:py-24">
    <h1 class="text-ink text-4xl font-bold">Privacy Policy</h1>
    <p class="text-muted mt-2 text-sm">Last updated: {updated}</p>

    <div
      class="border-brand-200 bg-tint/50 text-ink mt-6 rounded-xl border p-4 text-sm"
      role="note"
    >
      <strong>Placeholder.</strong> This is template copy to be replaced with Agora Data Driven's finalized
      privacy policy. Provide the final text and we'll drop it in.
    </div>

    <div class="text-body mt-8 space-y-6">
      <section>
        <h2 class="text-ink text-xl font-semibold">Overview</h2>
        <p class="text-muted mt-2">
          This policy explains what information we collect, how we use it, and the choices you have.
          Agora Data Driven respects your privacy and only collects what is needed to provide and
          improve our services.
        </p>
      </section>
      <section>
        <h2 class="text-ink text-xl font-semibold">Information we collect</h2>
        <p class="text-muted mt-2">
          Details you choose to share when contacting us, and standard analytics about how visitors
          use this website.
        </p>
      </section>
      <section>
        <h2 class="text-ink text-xl font-semibold">How to reach us</h2>
        <p class="text-muted mt-2">
          Questions about this policy? Contact us through our
          <a
            class="text-brand-600 hover:text-brand-700 font-medium"
            href="https://www.upwork.com/agencies/1818954484693860352/"
            target="_blank"
            rel="noopener noreferrer">Upwork agency profile</a
          >.
        </p>
      </section>
    </div>
  </Container>
</BaseLayout>
